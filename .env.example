# Copy this file to ".env" and paste your Anthropic API key below.
# Get a key at https://console.anthropic.com/settings/keys
# The key is read only by the dev-server proxy (vite.config.js) and is never
# exposed to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs text-to-speech key and optional voice override.
# Get the key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Optional: paste a voice_id from your ElevenLabs Voice Library.
ELEVENLABS_VOICE_ID=pqHfZKP75CvOlQylNhV4

# Optional latency/quality tuning (sensible low-latency defaults if left blank).
# Model: eleven_flash_v2_5 (fastest, default) · eleven_turbo_v2_5 (warmer) ·
#        eleven_multilingual_v2 (highest fidelity, slowest).
ELEVENLABS_MODEL_ID=
# Audio format: mp3_22050_32 (lightest, default) · mp3_44100_64 · mp3_44100_128 (richest).
ELEVENLABS_OUTPUT_FORMAT=
